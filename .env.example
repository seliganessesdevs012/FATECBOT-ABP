# Postgres (usado pelo Compose)
POSTGRES_USER=seu_usuario_postgres
POSTGRES_PASSWORD=sua_senha_postgres_forte
POSTGRES_DB=seu_banco_postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Connection string — por padrão aponta para o serviço 'db' do Compose
DATABASE_URL=postgresql://seu_usuario_postgres:sua_senha_postgres_forte@db:5432/seu_banco_postgres

# JWT
JWT_SECRET=gere_um_segredo_forte_com_no_minimo_32_caracteres
JWT_EXPIRES_IN=8h

# Backend
PORT=3000
NODE_ENV=development

# Frontend (Vite)
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000/api/v1
VITE_ENABLE_DEVTOOLS=true